  "keyFeatures": [
    "Registro y gestión completa del ciclo de vida de visitas (Agendada → Realizada/Cancelada)",
    "Control de aforo diario y por turno con validación en tiempo real",
    "Dashboard operativo diario con vista de turnos y estados por color",
    "Calendario mensual de ocupación para planificación",
    "Gestión de gestores e instituciones educativas con integración Georef API",
    "Exportación de reportes PDF (diario, mensual, por rango, comprobante individual)",
    "Panel de estadísticas gerenciales con KPIs y evolución temporal",
    "Gestión de usuarios con roles (Admin / Guía) y baja lógica",
    "Días inhábiles configurables para bloquear fechas no disponibles",
    "Auditoría inmutable de todas las acciones del sistema",
    "Autenticación JWT con cierre de sesión automático por inactividad configurable"
  ],
  "publicApiSurface": [
